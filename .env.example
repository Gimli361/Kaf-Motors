# KAF Motors — ortam değişkenleri (kopyala: .env.local)
# Supabase > Project Settings > API üzerinden alınır.

# Public — tarayıcıya gönderilir, sorun değil.
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# GIZLI — yalnız sunucuda (Server Actions / Edge Functions). Asla client'a sızdırma.
# Vercel'de "Environment Variables" altına ekle; .env.local commit edilmez.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
